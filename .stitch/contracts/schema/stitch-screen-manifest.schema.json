{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jg.local/stitch-screen-manifest.schema.json",
  "title": "Stitch Screen Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractKind",
    "setId",
    "surfaceId",
    "surfaceRole",
    "status",
    "source",
    "ctaPriority",
    "states",
    "blocks",
    "validation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.1.0"
    },
    "contractKind": {
      "type": "string",
      "const": "screen-manifest"
    },
    "setId": {
      "type": "string",
      "minLength": 1
    },
    "surfaceId": {
      "type": "string",
      "minLength": 1
    },
    "surfaceRole": {
      "type": "string",
      "enum": ["root", "repeat", "independent", "shared"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "accepted", "historical"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "sourceRef", "projectId", "screenId", "url"],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        },
        "projectId": {
          "type": "string",
          "minLength": 1
        },
        "screenId": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "screenName": {
          "type": "string",
          "minLength": 1
        },
        "variantLabel": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ctaPriority": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "outcome"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": ["primary", "secondary", "tertiary"]
          },
          "outcome": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "states": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "required": ["default"]
    },
    "blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/block"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firstReadOrder", "requiredChecks"],
      "properties": {
        "firstReadOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "requiredChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blockId",
        "role",
        "sourceName",
        "children"
      ],
      "properties": {
        "blockId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "root",
            "section",
            "repeat-item",
            "overlay",
            "cta",
            "content",
            "status",
            "shared-chrome"
          ]
        },
        "sourceName": {
          "type": "string",
          "minLength": 1
        },
        "children": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "componentComposition": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/componentCompositionItem"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "componentCompositionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "componentId",
        "slot"
      ],
      "properties": {
        "componentId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slot": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "variant": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/componentCompositionItem"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
