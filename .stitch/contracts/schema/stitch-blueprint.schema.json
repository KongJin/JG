{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jg.local/stitch-blueprint.schema.json",
  "title": "Stitch Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractKind",
    "blueprintId",
    "surfaceRole",
    "blocks",
    "defaults"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.1.0"
    },
    "contractKind": {
      "type": "string",
      "const": "blueprint"
    },
    "blueprintId": {
      "type": "string",
      "minLength": 1
    },
    "surfaceRole": {
      "type": "string",
      "enum": ["root", "repeat", "independent", "shared"]
    },
    "description": {
      "type": "string"
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/block"
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["states", "validation"],
      "properties": {
        "states": {
          "$ref": "#/$defs/states"
        },
        "validation": {
          "$ref": "#/$defs/validation"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blockId",
        "role",
        "sourceName",
        "unityTargetPath",
        "layout",
        "children"
      ],
      "properties": {
        "blockId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "root",
            "section",
            "repeat-item",
            "overlay",
            "cta",
            "content",
            "status",
            "shared-chrome"
          ]
        },
        "sourceName": {
          "type": "string",
          "minLength": 1
        },
        "unityTargetPath": {
          "type": "string",
          "minLength": 1
        },
        "layout": {
          "$ref": "#/$defs/layout"
        },
        "children": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "padding", "gap", "alignment", "sticky", "scroll"],
      "properties": {
        "axis": {
          "type": "string",
          "enum": ["vertical", "horizontal", "overlay", "free"]
        },
        "padding": {
          "type": "integer",
          "minimum": 0
        },
        "gap": {
          "type": "integer",
          "minimum": 0
        },
        "minHeight": {
          "type": "integer",
          "minimum": 0
        },
        "minWidth": {
          "type": "integer",
          "minimum": 0
        },
        "alignment": {
          "type": "string",
          "enum": ["start", "center", "end", "stretch"]
        },
        "sticky": {
          "type": "boolean"
        },
        "scroll": {
          "type": "boolean"
        }
      }
    },
    "states": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "required": ["default"]
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame", "firstReadOrder", "requiredChecks", "smokeScripts"],
      "properties": {
        "frame": {
          "type": "string",
          "minLength": 1
        },
        "firstReadOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "smokeScripts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
