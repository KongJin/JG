{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jg.local/stitch-unity-map.schema.json",
  "title": "Stitch Unity Surface Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractKind",
    "surfaceId",
    "target",
    "contractRefs",
    "translationStrategy",
    "strategyMode",
    "blocks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "contractKind": {
      "type": "string",
      "const": "unity-surface-map"
    },
    "surfaceId": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "assetPath"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "prefab",
            "scene"
          ]
        },
        "assetPath": {
          "type": "string",
          "minLength": 1
        },
        "sceneRootPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contractRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestPath"
      ],
      "properties": {
        "manifestPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "translationStrategy": {
      "type": "string",
      "minLength": 1
    },
    "strategyMode": {
      "type": "string",
      "enum": [
        "patch",
        "generate",
        "generate-or-patch"
      ]
    },
    "artifactPaths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pipelineResult": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyDefinition"
      }
    },
    "blocks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/blockMapping"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "blockMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hostPath"
      ],
      "properties": {
        "hostPath": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredComponents": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stateBindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stateBinding"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "stateBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "default",
            "selected",
            "empty",
            "loading",
            "error",
            "disabled"
          ]
        },
        "targetPath": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "dependencyDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "required"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "menu"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "menuPath": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
