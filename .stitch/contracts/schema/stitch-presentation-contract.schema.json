{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jg.local/stitch-presentation-contract.schema.json",
  "title": "Stitch Presentation Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractKind",
    "surfaceId",
    "surfaceRole",
    "extractionStatus",
    "sourceRefs",
    "derivedFrom",
    "unresolvedDerivedFields",
    "elements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "contractKind": {
      "type": "string",
      "const": "presentation-contract"
    },
    "surfaceId": {
      "type": "string",
      "minLength": 1
    },
    "surfaceRole": {
      "type": "string",
      "enum": ["root", "repeat", "independent", "shared", "overlay"]
    },
    "extractionStatus": {
      "type": "string",
      "enum": ["pending-source-derivation", "resolved", "historical"]
    },
    "sourceRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["imagePath", "htmlPath"],
      "properties": {
        "imagePath": {
          "type": "string",
          "minLength": 1
        },
        "htmlPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "derivedFrom": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/derivedValue"
      }
    },
    "unresolvedDerivedFields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/element"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "derivedValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "components": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "siblingIndex": {
          "type": "integer",
          "minimum": 0
        },
        "rect": {
          "$ref": "#/$defs/rect"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/propertyDefinition"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "rect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anchorMin": {
          "type": "string",
          "minLength": 1
        },
        "anchorMax": {
          "type": "string",
          "minLength": 1
        },
        "pivot": {
          "type": "string",
          "minLength": 1
        },
        "anchoredPosition": {
          "type": "string",
          "minLength": 1
        },
        "sizeDelta": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "propertyDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["componentType", "propertyName", "value"],
      "properties": {
        "componentType": {
          "type": "string",
          "minLength": 1
        },
        "propertyName": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        }
      }
    }
  }
}
