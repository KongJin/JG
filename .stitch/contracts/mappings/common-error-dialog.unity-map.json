{
  "schemaVersion": "1.0.0",
  "contractKind": "unity-surface-map",
  "surfaceId": "common-error-dialog",
  "target": {
    "kind": "prefab",
    "assetPath": "Assets/Prefabs/Features/Common/Independent/CommonErrorDialogRoot.prefab"
  },
  "contractRefs": {
    "manifestPath": ".stitch/contracts/screens/set-c-common-error-dialog.screen.json",
    "presentationPath": ".stitch/contracts/presentations/common-error-dialog.presentation.json"
  },
  "translationStrategy": "contract-complete-translator-v1",
  "strategyMode": "generate-or-patch",
  "artifactPaths": {
    "translationResult": "artifacts/unity/set-c-common-error-dialog-translation-result.json",
    "preflightResult": "artifacts/unity/set-c-common-error-dialog-preflight-result.json",
    "pipelineResult": "artifacts/unity/set-c-common-error-dialog-pipeline-result.json"
  },
  "blocks": {
    "error-header": {
      "hostPath": "DialogPanel/HeaderRow",
      "requiredComponents": [
        "Image",
        "HorizontalLayoutGroup"
      ]
    },
    "error-copy": {
      "hostPath": "DialogPanel/BodyBlock",
      "requiredComponents": [
        "LayoutElement"
      ]
    },
    "footer-actions": {
      "hostPath": "DialogPanel/FooterRow",
      "requiredComponents": [
        "HorizontalLayoutGroup",
        "LayoutElement"
      ]
    },
    "dismiss-cta": {
      "hostPath": "DialogPanel/FooterRow/DismissButton",
      "requiredComponents": [
        "Button",
        "Image",
        "LayoutElement"
      ]
    },
    "retry-cta": {
      "hostPath": "DialogPanel/FooterRow/RetryButton",
      "requiredComponents": [
        "Button",
        "Image",
        "LayoutElement"
      ]
    }
  },
  "notes": [
    "Independent overlay target for Set C common error dialog.",
    "Root includes scrim and dialog shell so it can be mounted over hangar or login flows."
  ]
