```mermaid
sequenceDiagram
    %% ========================================
    %% Layer Sequence Diagram - Garage Feature
    %% Unity UI Toolkit 기반 아키텍처
    %% ========================================

    actor User as 사용자
    participant UI as UI Toolkit<br/>(UIDocument/VisualElement)
    participant Surface as Presentation.Surface<br/>(GarageSetBSlotSurface)
    participant Adapter as Presentation.Adapter<br/>(GarageSetBUitkRuntimeAdapter)
    participant Controller as Presentation.Controller<br/>(GarageSetBUitkPageController)
    participant Presenter as Presentation.Presenter<br/>(GaragePagePresenter)
    participant UseCase as Application.UseCase<br/>(InitializeGarageUseCase,<br/>SaveRosterUseCase)
    participant Port as Application.Port<br/>(IGaragePersistencePort,<br/>IGarageNetworkPort)
    participant Domain as Domain<br/>(GarageRoster,<br/>UnitLoadout)
    participant Infra as Infrastructure<br/>(GarageJsonPersistence,<br/>GarageNetworkAdapter)
    participant EventBus as EventBus<br/>(IEventPublisher)

    %% ========== 초기화 플로우 ==========
    rect rgb(230, 245, 255)
        Note over User,EventBus: 초기화 플로우
        User->>Controller: Initialize(UseCases, Catalog)
        Controller->>UseCase: Execute()
        UseCase->>Port: Load() (로컬 캐시)
        Port->>Infra: Load() (JSON 파일)
        Infra-->>Port: GarageRoster
        Port-->>UseCase: GarageRoster
        UseCase-->>Controller: GarageRoster
        Controller->>Domain: Initialize(roster)
        Controller->>Presenter: BuildSlotViewModels(state)
        Presenter->>Domain: GetSlot(i)
        Domain-->>Presenter: UnitLoadout
        Presenter-->>Controller: List<GarageSlotViewModel>
        Controller->>Adapter: Render(viewModel)
        Adapter->>Surface: Render(viewModel)
        Surface->>UI: Update VisualElement
        UI-->>User: 초기 UI 표시
    end

    %% ========== 슬롯 선택 플로우 ==========
    rect rgb(255, 245, 230)
        Note over User,EventBus: 슬롯 선택 플로우
        User->>UI: 슬롯 클릭
        UI->>Surface: SlotSelected 이벤트
        Surface->>Adapter: SlotSelected 이벤트
        Adapter->>Controller: SlotSelected 이벤트
        Controller->>Controller: SelectSlot(index)
        Controller->>Domain: SelectSlot(index)
        Controller->>Presenter: BuildSlotViewModels(state)
        Presenter->>Domain: GetSlot(i)
        Domain-->>Presenter: UnitLoadout
        Presenter-->>Controller: List<GarageSlotViewModel>
        Controller->>Adapter: Render(viewModel)
        Adapter->>Surface: Render(viewModel)
        Surface->>UI: Update VisualElement
        UI-->>User: 선택된 슬롯 하이라이트
    end

    %% ========== 파츠 선택 플로우 ==========
    rect rgb(245, 255, 230)
        Note over User,EventBus: 파츠 선택 플로우
        User->>UI: 파츠 옵션 선택
        UI->>Surface: PartOptionSelected 이벤트
        Surface->>Adapter: PartOptionSelected 이벤트
        Adapter->>Controller: PartOptionSelected 이벤트
        Controller->>Controller: SelectPartOption(selection)
        Controller->>Domain: SetEditingFrameId(id)<br/>SetEditingFirepowerId(id)<br/>SetEditingMobilityId(id)
        Controller->>Presenter: BuildEditorViewModel(state)
        Presenter-->>Controller: GarageEditorViewModel
        Controller->>UseCase: ComposeUnit()
        UseCase->>Domain: Compose()
        Domain-->>UseCase: Unit (스펙 계산)
        UseCase-->>Controller: Result<Unit>
        Controller->>Presenter: BuildResultViewModel()
        Presenter-->>Controller: GarageResultViewModel
        Controller->>Adapter: Render(viewModel)
        Adapter->>Surface: Render(viewModel)
        Surface->>UI: Update VisualElement
        UI-->>User: 업데이트된 에디터 및 스탯
    end

    %% ========== 저장 플로우 ==========
    rect rgb(255, 230, 245)
        Note over User,EventBus: 저장 플로우
        User->>UI: 저장 버튼 클릭
        UI->>Surface: SaveRequested 이벤트
        Surface->>Adapter: SaveRequested 이벤트
        Adapter->>Controller: SaveRequested 이벤트
        Controller->>Controller: RequestSave()
        Controller->>UseCase: Execute(roster)
        UseCase->>Domain: Normalize()
        UseCase->>Port: Save(roster)
        Port->>Infra: Save(roster)
        Infra->>Infra: JSON 직렬화 &<br/>파일 쓰기
        Infra-->>Port: void
        Port-->>UseCase: void
        UseCase->>Port: SyncRoster(roster) (네트워크)
        Port->>Infra: SyncRoster(roster)
        Infra->>Infra: Photon CustomProperties<br/>동기화
        Infra-->>Port: void
        Port-->>UseCase: void
        UseCase-->>Controller: Result.Success()
        Controller->>Domain: CommitSelectedSlotDraft()
        Controller->>EventBus: Publish(GarageDraftStateChangedEvent)
        EventBus->>EventBus: 구독자들에게 알림
        Controller->>Presenter: BuildResultViewModel()
        Presenter-->>Controller: GarageResultViewModel
        Controller->>Adapter: Render(viewModel)
        Adapter->>Surface: Render(viewModel)
        Surface->>UI: Update VisualElement
        UI-->>User: 저장 완료 메시지
    end

    %% ========== 레이어 경계 표시 ==========
    Note left of Surface: ====================<br/>Presentation Layer<br/>(UI Surface, Adapter,<br/>Controller, Presenter,<br/>ViewModels)
    Note left of UseCase: ====================<br/>Application Layer<br/>(UseCases, Ports/Interfaces,<br/>Events)
    Note left of Domain: ====================<br/>Domain Layer<br/>(Business Entities,<br/>Business Logic)
    Note left of Infra: ====================<br/>Infrastructure Layer<br/>(Persistence,<br/>Network, Data Catalogs)
```
