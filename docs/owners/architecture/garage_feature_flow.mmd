```mermaid
flowchart TB
    %% ========================================
    %% Garage Feature - Complete Flow
    %% 사용자 상호작용부터 저장까지의 전체 플로우
    %% ========================================

    Start((사용자 진입)) --> Init

    subgraph Initialization["초기화 단계"]
        direction TB
        Init[GarageSetBUitkPageController.<br/>Initialize()] --> UseCaseInit[InitializeGarageUseCase.<br/>Execute()]
        UseCaseInit --> PortLoad[IGaragePersistencePort.<br/>Load()]
        PortLoad --> InfraLoad[GarageJsonPersistence.<br/>Load()]
        InfraLoad -->|GarageRoster| PortLoad
        PortLoad -->|GarageRoster| UseCaseInit
        UseCaseInit -->|GarageRoster| InitState[GaragePageState.<br/>Initialize()]
        InitState --> BuildVM1[GaragePageViewModelBuilders.<br/>BuildSlotViewModels()]
        BuildVM1 --> RenderInit[Render()]
        RenderInit --> UIInit[UI 업데이트]
    end

    UIInit --> UserAction

    subgraph Interaction["상호작용 단계"]
        direction TB
        UserAction{사용자 동작}

        UserAction -->|슬롯 선택| SlotFlow
        UserAction -->|파츠 선택| PartFlow
        UserAction -->|검색| SearchFlow
        UserAction -->|저장| SaveFlow

        subgraph SlotFlow["슬롯 선택 플로우"]
            direction TB
            SlotClick[슬롯 클릭] --> SlotEvent[SlotSelected 이벤트]
            SlotEvent --> SlotSelect[SelectSlot index]
            SlotSelect --> ClearFocus[focusedPart = Mobility]
            SlotSelect --> ClearSearch[partSearchText = ""]
            ClearFocus & ClearSearch --> BuildVM2[BuildSlotViewModels]
            BuildVM2 --> Render1[Render]
        end

        subgraph PartFlow["파츠 선택 플로우"]
            direction TB
            PartClick[파츠 옵션 클릭] --> PartEvent[PartOptionSelected 이벤트]
            PartEvent --> PartSelect[SelectPartOption]
            PartSelect -->|Frame| SetFrame[SetEditingFrameId]
            PartSelect -->|Firepower| SetFire[SetEditingFirepowerId]
            PartSelect -->|Mobility| SetMob[SetEditingMobilityId]
            SetFrame & SetFire & SetMob --> Compose[ComposeUnitUseCase.<br/>Execute]
            Compose -->|Unit| DomainCalc[Domain 스펙 계산]
            DomainCalc -->|Unit| Compose
            Compose -->|Result<Unit>| BuildEditor[BuildEditorViewModel]
            BuildEditor --> BuildResult[BuildResultViewModel]
            BuildResult --> Render2[Render]
        end

        subgraph SearchFlow["검색 플로우"]
            direction TB
            SearchInput[검색어 입력] --> SearchEvent[PartSearchChanged 이벤트]
            SearchEvent --> SetSearch[SetPartSearchText]
            SetSearch --> BuildPartList[BuildPartListViewModel]
            BuildPartList --> Render3[Render]
        end

        Render1 --> RenderAll
        Render2 --> RenderAll
        Render3 --> RenderAll

        subgraph SaveFlow["저장 플로우"]
            direction TB
            SaveClick[저장 버튼 클릭] --> SaveEvent[SaveRequested 이벤트]
            SaveEvent --> Validate[ValidateRosterUseCase.<br/>Execute]
            Validate -->|Result| EvaluateDraft[GarageDraftEvaluation.<br/>Evaluate]
            EvaluateDraft -->|유효함| SaveExec[SaveRosterUseCase.<br/>Execute]
            EvaluateDraft -->|유효하지 않음| SetError[SetValidationOverride]

            SaveExec --> Persist[IGaragePersistencePort.<br/>Save]
            Persist -->|roster| InfraSave[GarageJsonPersistence.<br/>Save]
            InfraSave -->|JSON 직렬화| FileWrite[파일 쓰기]
            FileWrite --> Persist

            SaveExec --> Sync[IGarageNetworkPort.<br/>SyncRoster]
            Sync -->|roster| InfraSync[GarageNetworkAdapter]
            InfraSync -->|CustomProperties| PhotonSync[Photon 동기화]
            PhotonSync --> Sync

            Persist -->|Result.Success| Commit[CommitSelectedSlotDraft]
            Sync -->|Result.Success| Commit
            Commit --> PublishEvent[Publish<br/>GarageDraftStateChangedEvent]
            PublishEvent --> BuildVM3[BuildResultViewModel]
            BuildVM3 --> RenderSave[Render]
        end

        RenderAll --> UIUpdate
        RenderSave --> UIUpdate
        SetError --> UIUpdate
    end

    UIUpdate --> UIRender((UI 렌더링))

    UIRender --> UserAction

    %% Styling
    classDef init fill:#e3f2fd,stroke:#1565c0
    classDef interaction fill:#fff3e0,stroke:#ef6c00
    classDef flow fill:#e8f5e9,stroke:#2e7d32
    classDef save fill:#f3e5f5,stroke:#7b1fa2
    classDef terminal fill:#ffebee,stroke:#c62828

    class Init,UseCaseInit,PortLoad,InfraLoad,InitState,BuildVM1,RenderInit,UIInit init
    class UserAction,SlotClick,PartClick,SearchInput interaction
    class SlotFlow,PartFlow,SearchFlow flow
    class SaveFlow,SaveClick,Validate,SaveExec,Persist,InfraSave,FileWrite,Sync,InfraSync,PhotonSync,Commit,PublishEvent save
    class Start,UIRender terminal
```
