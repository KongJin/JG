{
  "name": "jg",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "docs:lint": "node ./tools/docs-lint/docs-lint.mjs",
    "docs:health": "node ./tools/docs-lint/docs-health.mjs",
    "docs:sync-progress": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\docs-lint\\sync-progress.ps1",
    "rules:sync-closeout": "node ./tools/docs-lint/sync-recurrence-closeout.mjs",
    "stitch:policy:lint": "node ./tools/stitch-unity/lint-stitch-driven-policy.mjs",
    "feature:presentation:lint": "node ./tools/workflow/test-garage-presentation-structure.mjs",
    "feature:layer:lint": "node ./tools/workflow/test-feature-layer-dependencies.mjs",
    "runtime:static-ui-ownership:lint": "node ./tools/workflow/test-runtime-static-ui-ownership.mjs",
    "runtime:hotspots:lint": "node ./tools/workflow/test-runtime-hotspot-structure.mjs",
    "garage:presentation:lint": "npm run --silent feature:presentation:lint",
    "policy:lint": "node ./tools/docs-lint/policy-lint.mjs && npm run --silent stitch:policy:lint && npm run --silent feature:presentation:lint && npm run --silent feature:layer:lint && npm run --silent runtime:static-ui-ownership:lint && npm run --silent runtime:hotspots:lint",
    "rules:lint": "npm run --silent docs:lint && npm run --silent policy:lint",
    "unity:asset-hygiene": "powershell -ExecutionPolicy Bypass -File .\\tools\\check-unity-asset-hygiene.ps1",
    "workflow:agent-review": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Invoke-AgentPassReview.ps1",
    "workflow:closeout": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Invoke-CloseoutPack.ps1",
    "workflow:simplify": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Find-SimplificationCandidates.ps1",
    "workflow:artifact-scope": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Test-GeneratedArtifactScope.ps1",
    "workflow:unity-test-preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Test-UnityCliRunTestsPreflight.ps1",
    "workflow:unity-editmode-tests": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Invoke-UnityEditModeTests.ps1",
    "workflow:next": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\workflow\\Get-NextWorkSuggestion.ps1",
    "audio:mcp:build": "tsc -p tools/audio-mcp/tsconfig.json",
    "audio:mcp:test": "npm run --silent audio:mcp:build && node --test tools/audio-mcp/tests/audioPipeline.test.mjs",
    "stitch:help": "node ./tools/stitch/stitch-inspect.mjs help",
    "stitch:list:projects": "node ./tools/stitch/stitch-inspect.mjs list-projects",
    "stitch:create:project": "node ./tools/stitch/stitch-inspect.mjs create-project",
    "stitch:create:design-system": "node ./tools/stitch/stitch-inspect.mjs create-design-system",
    "stitch:generate:screen": "node ./tools/stitch/stitch-inspect.mjs generate-screen",
    "stitch:bootstrap:jg": "node ./tools/stitch/stitch-inspect.mjs bootstrap-jg",
    "stitch:list:screens": "node ./tools/stitch/stitch-inspect.mjs list-screens",
    "stitch:fetch:screen": "node ./tools/stitch/stitch-inspect.mjs fetch-screen",
    "stitch:mcp:proxy": "node ./tools/stitch/stitch-mcp-proxy.mjs",
    "serena:mcp:proxy": "node ./tools/serena-shared-proxy/serena-shared-proxy.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@google/stitch-sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.1"
  }
}
