res.item = new Piece(res.sheet1, 0, 0, ITEM_WIDTH, ITEM_HEIGHT);
res.cursor = new Piece("mouseCursor.bmp", 0, 0, 32, 32);
res.scrollBar = new DrawScrollBar;
res.cursorUp = new PieceSet(res.sheet2);
res.cursorUp.setPieceRect(1, 396, 331, 21, 16);
res.cursorUp.setPieceRect(2, 419, 331, 21, 16);
res.cursorDown = new PieceSet(res.sheet2);
res.cursorDown.setPieceRect(1, 373, 311, 21, 16);
res.cursorDown.setPieceRect(2, 352, 311, 21, 16);

// 전경, 리스트보다 앞에 있다.
var fg = new Component;
fg.resize(0, 0, 1024, 768);
fg.drawable = res.fg;
fg.onhittest = function () { return false; };
