//message("test");

var sellItems = {};

// 버튼 추가 함수
function addButton(host, img, x, y, width, height, offsets, onclick) {
    var btn = new Button;
    btn.resize(x, y, width, height);
    var imgset = new PieceSet(img);
    btn.drawable = imgset;
    btn.onclick = onclick;

    btn.resetImages = function () {
        var count = offsets.length / 2;
        for (var i = 0; i < count; i++) {
            var ox = offsets[i * 2];
            var oy = offsets[i * 2 + 1];
            if (ox == -1) {
                imgset.setPieceRect(i, 0, 0, 0, 0);
                continue;
            }
            imgset.setPieceRect(i, ox, oy, width, height);
        }
    };
    btn.resetImages();
    host.attach(btn);
    return btn;
};

// 탭 추가 함수
function addTab(host, img, x, y, width, height, offsets, type) {
    var tab = addButton(host, img, x, y, width, height, offsets);
    var imgset = tab.drawable;
    var scroll = new ScrollBar();
    var list = new Component; // new ListBox;
    var haveItems = [];

    list.resize(60, 150, ITEM_WIDTH * 2 + 10, 600);
    list.scroll = scroll;

    scroll.resize(995, 219, 21, 366);
    scroll.itemHeight = ITEM_HEIGHT;
    scroll.barDrawable = res.scrollBar;
    scroll.upDrawable = res.cursorUp;
    scroll.downDrawable = res.cursorDown;

    tab.disableTab = function () {
        tab.list.remove();
        tab.listScroll.remove();
        tab.resetImages();
    };
    tab.onlbuttondown = function () {
        if (enableTab != null)
        {
            if (enableTab == this)
                return;
            enableTab.disableTab();
        }
        for (var i = 0; i < 3; i++)
            imgset.setPieceRect(i, offsets[6], offsets[7], width, height);
        scene.insertBefore(tab.list, fg);
        scene.attach(scroll);
        enableTab = this;
    };

    var items = [];

    tab.addItem = function (modelno) {
        if (/^[0-9]*$/.test(modelno))
            modelno = parseInt(modelno);
        var item = new Component;
        item.drawable = res.item;
        var modelview = new ModelViewer();
        modelview.scene = new GxModel(modelno);
        modelview.camera.fovY = 0.5;
        modelview.camera.far = 1000;
		if (typeof(modelno) == "number") {
	        switch((modelno / 1000) | 0)
	        {
	            case 3: // 무기 부품
	                modelview.camera.target.y -= 0.5;
	                break;
	            case 1: // 다리 부품
	                modelview.camera.target.y -= 0.5;
	                break;
	            case 2: // 몸통 부품
	                modelview.camera.target.y -= 1;
	                break;
	            case 6: // 악세사리
	                modelview.camera.target.y -= 0.3;
	                break;
	            case 8:
	                modelview.camera.far = 100;
	                modelview.camera.target.y += 1;
	                modelview.camera.position.z -= 20;
	                break;
	            default:
	              //  alert(modelno);
	        }
		}
		else {
		    modelview.camera.target.y -= 0.5;
		    modelview.camera.position.z += 1;
		}

        modelview.matrix = itemMatrix;
        modelview.resize(20, 19, 128, 128);
        item.attach(modelview);
        item.ondraw = function () {
        };
        item.setIndex = function (n) {
            var x = 0;
            if (n % 2 == 0) {
                x = 5;
            }
            else {
                x = ITEM_WIDTH + 10;
            }
            this.index = n
            var y = ((n / 2) | 0) * ITEM_GAP_HEIGHT;
            this.resize(x, y, ITEM_WIDTH, ITEM_HEIGHT);
        };
        item.setIndex(items.length);
        items.push(item);
        tab.list.attach(item);
        tab.resetScrollRange();
        return item;
    };
    tab.addSellItem = function (iteminfo) {
        var item = this.addItem(iteminfo.model);
        item.ondraw = function () {
            ctx.__novaFont.font = 2;
            ctx.color = 0xffeeeeee;
            ctx.__novaFont.fill(iteminfo.name, 170, 33);
            if (iteminfo.cost != 0) {
                ctx.color = 0xffffff00;
                ctx.__novaFont.fill(iteminfo.cost + " CASH", 170, 67);
            }
            else {
                ctx.color = 0xffff0000;
                ctx.__novaFont.fill("준비중", 170, 67);
            }
            ctx.color = 0xffeeeeee;
            ctx.__novaFont.font = 0;
            ctx.__novaFont.widthLimit = 190;
            ctx.__novaFont.lineWidth = 20;
            ctx.__novaFont.fill(iteminfo.info, 167, 104);
            ctx.color = 0xffffffff;
        };
        addButton(item, res.sheet1, 365, 83, 70, 70, [-1, -1, -1, -1, 365, 185], function () {
            scene.buyRequest(iteminfo.code);
        });
    };
    tab.resetScrollRange = function () {
        scroll.range = (((items.length + 1) / 2) | 0) * ITEM_GAP_HEIGHT + 60;
    };
    tab.removeHaveItem = function (slot) {
        var haveitem = haveItems[slot];
        if (haveitem == null)
            return null;
        haveItems[slot] = null;
        for (var i = slot + 1; i < haveItems.length; i++)
            haveItems[i].slot--;
        haveItems.splice(slot, 1);
        for (var i = haveitem.index + 1; i < items.length; i++) {
            var item = items[i];
            item.setIndex(item.index - 1);
        }
        items.splice(haveitem.index, 1);

        items.length;
        haveitem.remove();
        return haveitem.info.code;
    };

    tab.addHaveItem = function (slot, iteminfo) {
        var item = this.addItem(iteminfo.model);
        item.slot = slot;
        haveItems[item.slot] = item;
        item.info = iteminfo;
        item.ondraw = function () {
            ctx.__novaFont.font = 2;
            ctx.color = 0xffeeeeee;
            ctx.__novaFont.fill(iteminfo.name, 170, 33);
            ctx.color = 0xffeeeeee;
            ctx.__novaFont.font = 0;
            ctx.__novaFont.widthLimit = 190;
            ctx.__novaFont.lineWidth = 20;
            ctx.__novaFont.fill(iteminfo.info, 167, 104);
            ctx.color = 0xffffffff;
        };
        addButton(item, res.sheet1, 365, 10, 70, 70, [365, 357, 365, 357, 438, 185], function () {
            scene.cancelRequest(item.info.code, item.slot);
        });
        addButton(item, res.sheet1, 365, 83, 70, 70, [365, 431, 365, 431, 438, 256], function () {
            scene.useRequest(item.info.code, item.slot);
        });
    }

    tab.listScroll = scroll;
    tab.list = list;

    return tab;
}

var enableTab = null;

