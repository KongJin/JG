    enableTab.listScroll.moveScroll(0);
});

// 스크롤 Down 2
addButton(scene, res.sheet2, 995, 584, 21, 16, [-1, -1, 373, 331, 352, 331], function () { enableTab.listScroll.moveScroll(enableTab.listScroll.range); });

// 탭들
var tab = {};
tab.main = addTab(scene, res.sheet2, 94, 71, 115, 57, [-1, -1, 1, 1, 1, 59, 1, 118]); // 메인
tab.skin = addTab(scene, res.sheet2, 200, 71, 117, 57, [-1, -1, 236, 1, 236, 59, 236, 118]); // 스킨
tab.booster = addTab(scene, res.sheet2, 307, 71, 118, 57, [-1, -1, 117, 1, 117, 59, 117, 118]); // 부스터
tab.etc = addTab(scene, res.sheet2, 416, 71, 117, 57, [-1, -1, 354, 1, 354, 59, 354, 118]); // 기타
tab.have = addTab(scene, res.sheet2, 658, 71, 116, 57, [-1, -1, 1, 311, 118, 311, 234, 311]); // 보유
tab.main.onlbuttondown();

function clone(obj) {
    var newObject = {};
    for (var p in obj)
        newObject[p] = obj[p];
    return newObject;
}

// 보유 아이템 수신
scene.onitem = function (slot, code) {
    var iteminfo = sellItems[code];
    if (!iteminfo) {
        iteminfo = clone(sellItems.NULL);
        iteminfo.code = code;
        iteminfo.name = code;

        // 여기서 하면 됨.
        if (iteminfo.code.substr(0, 5) == "GOLD_")
        {
            
        }
        else if(iteminfo.code.substr(0, 5) == "LUCK_")
        {

        }
        else if (iteminfo.code.substr(0, 5) == "ITEM_")
        {

        }

        sellItems[code] = iteminfo;
    }
    tab.have.addHaveItem(slot, iteminfo);
    tab.have.onlbuttondown();
};

// 아이템 삭제
scene.onitemremove = function (slot) {
    return tab.have.removeHaveItem(slot);
};

// 판매 아이템 수신
scene.onsellitem = function (type, main, sell, model, code, name, cost, info) {
    var iteminfo = sellItems[code] = {
        "type": type,
        "main": main,
        "sell": sell,
        "model": model,
        "code": code,
        "name": name,
        "cost": cost,
        "info": info
    };
    if (sell)
    {
        if (main) {
            tab.main.addSellItem(iteminfo);
        }
        switch (type) {
            case 0: // Skin
                tab.skin.addSellItem(iteminfo);
                break;
            case 1: //Booster
                tab.booster.addSellItem(iteminfo);
                break;
            case 2: // Etc
                tab.etc.addSellItem(iteminfo);
                break;
        }
    }
};

scene.onkeydown = function (key) {
    if (key == 13)
        return true;
    if (key == 27) {
        moveScene("exit");
        return true;
    }
    if (key == 116)
        reload();
}

// 충전하기
addButton(scene, res.sheet2, 794, 73, 230, 87, [-1, -1, 1, 377, 232, 377], function () {
    scene.openCashCharge();
});

