{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kongjin.github.io/jg/rule-harness-report.schema.json",
  "title": "Rule Harness Report",
  "type": "object",
  "required": [
    "runId",
    "commitSha",
    "execution",
    "scannedFeatures",
    "scannedScopes",
    "completedScopes",
    "stoppedScope",
    "nextScopeCandidates",
    "findings",
    "docProposals",
    "docEdits",
    "plannedBatches",
    "appliedBatches",
    "skippedBatches",
    "rollbackBatches",
    "stageResults",
    "actionItems",
    "decisionTrace",
    "validationResults",
    "discoveredValidationPlan",
    "learningTrace",
    "memoryHits",
    "memoryUpdates",
    "promotionCandidates",
    "retryAttempts",
    "historySummary",
    "commit",
    "rollback",
    "applied",
    "failed"
  ],
  "properties": {
    "runId": {
      "type": "string"
    },
    "commitSha": {
      "type": "string"
    },
    "execution": {
      "type": "object",
      "required": [
        "dryRun",
        "llmEnabled",
        "llmModel",
        "llmApiBaseUrl",
        "mutationEnabled",
        "mutationMode",
        "statePath",
        "branch",
        "docProposalPath",
        "compileVerified",
        "cleanLevel",
        "compileGateStatus",
        "compileGateReasonCode",
        "compileStatusPath",
        "featureDependencyGateStatus",
        "featureDependencyCycleCount",
        "featureDependencyReportPath",
        "featureDependencyRepairStatus",
        "featureDependencyRepairAttemptCount",
        "featureDependencyUnsupportedCycleCount"
      ],
      "properties": {
        "dryRun": {
          "type": "boolean"
        },
        "llmEnabled": {
          "type": "boolean"
        },
        "llmModel": {
          "type": [
            "string",
            "null"
          ]
        },
        "llmApiBaseUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "llmTimeoutSec": {
          "type": [
            "integer",
            "null"
          ]
        },
        "mutationEnabled": {
          "type": "boolean"
        },
        "mutationMode": {
          "enum": [
            "report_only",
            "doc_only",
            "code_and_rules"
          ]
        },
        "reportPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "summaryPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "logPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "docProposalPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "compileVerified": {
          "type": "boolean"
        },
        "cleanLevel": {
          "type": "string"
        },
        "compileGateStatus": {
          "type": "string"
        },
        "compileGateReasonCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "compileStatusPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "featureDependencyGateStatus": {
          "type": "string"
        },
        "featureDependencyCycleCount": {
          "type": "integer"
        },
        "featureDependencyReportPath": {
          "type": "string"
        },
        "featureDependencyRepairStatus": {
          "type": "string"
        },
        "featureDependencyRepairAttemptCount": {
          "type": "integer"
        },
        "featureDependencyUnsupportedCycleCount": {
          "type": "integer"
        },
        "statePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "scannedFeatures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scannedScopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completedScopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stoppedScope": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "scopeId": {
          "type": "string"
        },
        "findingCount": {
          "type": "integer"
        },
        "highestSeverity": {
          "type": [
            "string",
            "null"
          ]
        },
        "plannedBatchCount": {
          "type": "integer"
        },
        "docProposalCount": {
          "type": "integer"
        },
        "finalStatus": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "clean",
            "findings",
            "failed",
            null
          ]
        },
        "remainingFindingCount": {
          "type": [
            "integer",
            "null"
          ]
        },
        "resolvedInRun": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "nextScopeCandidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "findingType",
          "severity",
          "ownerDoc",
          "evidence",
          "confidence"
        ],
        "properties": {
          "findingType": {
            "enum": [
              "code_violation",
              "doc_drift",
              "missing_rule",
              "broken_reference"
            ]
          },
          "severity": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "ownerDoc": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "remediationKind": {
            "enum": [
              "code_fix",
              "rule_fix",
              "mixed_fix",
              "report_only"
            ]
          },
          "rationale": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "line": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "snippet": {
                  "type": "string"
                }
              }
            }
          },
          "proposedDocEdit": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    },
    "docEdits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "targetPath",
          "status"
        ],
        "properties": {
          "targetPath": {
            "type": "string"
          },
          "status": {
            "enum": [
              "proposed",
              "applied",
              "skipped",
              "rejected",
              "failed"
            ]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "plannedBatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "targetFiles",
          "reason",
          "validation",
          "expectedFindingsResolved",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "code_fix",
              "rule_fix",
              "mixed_fix"
            ]
          },
          "targetFiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expectedFindingsResolved": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          },
          "riskScore": {
            "type": [
              "integer",
              "null"
            ]
          },
          "riskLabel": {
            "type": [
              "string",
              "null"
            ]
          },
          "fingerprint": {
            "type": [
              "string",
              "null"
            ]
          },
          "ownershipStatus": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "appliedBatches": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "skippedBatches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "reasonCode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "fingerprint": {
            "type": [
              "string",
              "null"
            ]
          },
          "attemptCount": {
            "type": "integer"
          }
        }
      }
    },
    "rollbackBatches": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "stageResults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "status",
          "attempted",
          "summary"
        ],
        "properties": {
          "stage": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "attempted": {
            "type": "boolean"
          },
          "summary": {
            "type": "string"
          },
          "details": {
            "type": [
              "object",
              "array",
              "string",
              "null"
            ]
          }
        }
      }
    },
    "actionItems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "severity",
          "summary",
          "details",
          "relatedPaths"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "relatedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "decisionTrace": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validationResults": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "batchId": {
            "type": "string"
          },
          "validation": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "source": {
            "type": [
              "string",
              "null"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "discoveredValidationPlan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "batchId",
          "scopeType",
          "scopePath",
          "source",
          "confidence",
          "runnable",
          "featureTestAssets",
          "inferredChecks",
          "checks",
          "status"
        ],
        "properties": {
          "batchId": {
            "type": "string"
          },
          "scopeType": {
            "type": "string"
          },
          "scopePath": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "enum": [
              "rule-only",
              "inferred",
              "feature_test_assets"
            ]
          },
          "confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "runnable": {
            "type": "boolean"
          },
          "featureTestAssets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inferredChecks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "source",
                "runnable",
                "details"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "runnable": {
                  "type": "boolean"
                },
                "details": {
                  "type": "string"
                }
              }
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "source",
                "runnable",
                "details"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "runnable": {
                  "type": "boolean"
                },
                "details": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "type": "string"
          },
          "reasonCode": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "docProposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scopeId",
          "targetDoc",
          "severity",
          "summary",
          "normalizedSummary",
          "details",
          "suggestion",
          "relatedPaths",
          "evidence"
        ],
        "properties": {
          "scopeId": {
            "type": "string"
          },
          "targetDoc": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "normalizedSummary": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          },
          "relatedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "learningTrace": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "memoryHits": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "memoryUpdates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "promotionCandidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "featureDependencyRepairSummaries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "featureDependencyRepairCodeCommits": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "featureDependencyRepairDocCommits": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "featureDependencyRepairPolicySnapshot": {
      "type": [
        "object",
        "null"
      ]
    },
    "retryAttempts": {
      "type": "integer"
    },
    "historySummary": {
      "type": "object",
      "required": [
        "statePath",
        "loadedEntryCount",
        "activeEntryCount",
        "gcRemovedCount",
        "touchedEntryCount"
      ],
      "properties": {
        "statePath": {
          "type": "string"
        },
        "loadedEntryCount": {
          "type": "integer"
        },
        "activeEntryCount": {
          "type": "integer"
        },
        "gcRemovedCount": {
          "type": "integer"
        },
        "touchedEntryCount": {
          "type": "integer"
        }
      }
    },
    "commit": {
      "type": "object",
      "required": [
        "attempted",
        "created",
        "sha",
        "branch",
        "message"
      ],
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "created": {
          "type": "boolean"
        },
        "sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "rollback": {
      "type": "object",
      "required": [
        "performed",
        "failedBatches"
      ],
      "properties": {
        "performed": {
          "type": "boolean"
        },
        "failedBatches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "applied": {
      "type": "boolean"
    },
    "failed": {
      "type": "boolean"
    }
  }
}
