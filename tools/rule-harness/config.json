{
  "scan": {
    "include": [
      "Assets/Scripts/**/*.cs"
    ],
    "maxScopesPerRun": 4,
    "exclude": [
      "Assets/FromStore/**",
      "Library/**",
      "Temp/**",
      "Build/**",
      "obj/**"
    ]
  },
  "ssot": {
    "scopeDocs": [
      "AGENTS.md"
    ]
  },
  "docs": {
    "mutationEnabled": true,
    "allowlist": [
      "AGENTS.md",
      "agent/*.md"
    ],
    "denylist": [
      "docs/design/**"
    ]
  },
  "mutation": {
    "enabled": true,
    "mode": "code_and_rules",
    "branchPolicy": "current_branch",
    "commitMessagePrefix": "autofix(rule-harness):",
    "maxBatchesPerRun": 3,
    "maxFilesPerBatch": 8,
    "stopOnFirstFailure": true,
    "stopAfterFirstScopeWithErrors": true,
    "requireCleanTargets": true
  },
  "severityPolicy": {
    "missingSsotReference": "high",
    "missingFeatureBootstrap": "high",
    "unityInDomain": "high",
    "unityInApplication": "high",
    "hardcodedMcpUiSmoke": "high",
    "brokenReference": "medium",
    "agentFailure": "high"
  },
  "llm": {
    "defaultModel": "gpt-4.1-mini",
    "defaultApiBaseUrl": "https://api.openai.com/v1",
    "glmApiBaseUrl": "https://open.bigmodel.cn/api/paas/v4",
    "requestTimeoutSec": 120,
    "maxFindingsForReview": 40,
    "maxSnippetChars": 6000,
    "maxTargetDocCharsForSync": 20000
  },
  "history": {
    "statePath": "Temp/RuleHarnessState/history.json",
    "gcDays": 14,
    "maxAttemptsPerCommit": 2,
    "nonActionableReasons": [
      "dirty-target-files",
      "ownership-preflight-rejected",
      "manual-validation-required"
    ]
  },
  "state": {
    "featureScanStatePath": "Temp/RuleHarnessState/feature-scan-state.json",
    "docProposalBacklogPath": "Temp/RuleHarnessState/doc-proposals.json",
    "compileStatusPath": "Temp/RuleHarnessState/compile-status.json",
    "featureDependencyReportPath": "Temp/LayerDependencyValidator/feature-dependencies.json"
  },
  "validation": {
    "runHarnessTests": true,
    "harnessTestScript": "tools/rule-harness/tests/Run-RuleHarnessTests.ps1"
  },
  "cleanup": {
    "enabled": true,
    "mode": "aggressive",
    "maxAutoApplyBatchesPerRun": 2,
    "autoApplyKinds": [
      "delete_unused",
      "simplify_inline"
    ],
    "reportOnlyKinds": [
      "move_owner"
    ],
    "llmScout": {
      "enabled": true,
      "allowReadOnlyRepoInspection": true,
      "maxCandidateHints": 24,
      "roots": [
        "Assets/Scripts",
        "Assets/Resources",
        "docs",
        "tools"
      ]
    }
  },
  "learning": {
    "memoryPath": "tools/rule-harness/memory/advisory-memory.json",
    "maxSameRunAttempts": 2,
    "promotionMinHits": 3,
    "promotionMinDistinctCommits": 2
  },
  "agentRunner": {
    "enabled": true,
    "commandPath": "",
    "model": "gpt-5.4-mini",
    "reasoningEffort": "medium",
    "timeoutSec": 240,
    "maxTasksPerRun": 1,
    "requireChatGptLogin": true
  },
  "risk": {
    "enabled": true,
    "maxAutoApplyScoreByMode": {
      "report_only": 0,
      "doc_only": 25,
      "code_and_rules": 40
    },
    "scores": {
      "brokenReferenceDocFix": 10,
      "featureReadmeContract": 20,
      "featureRootScaffold": 30,
      "featureRootPlaceholderCleanup": 30,
      "existingCodeFileEdit": 60,
      "mixedRuleCodeBatch": 70,
      "agentDocPenalty": 20,
      "cleanupDeleteUnused": 30,
      "cleanupSimplifyInline": 35
    }
  },
  "ownership": {
    "enabled": true
  },
  "schedule": {
    "utcCron": "0 17 * * *",
    "kstTime": "02:00"
  }
}
