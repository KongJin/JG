{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "batches",
    "blocked",
    "actionItems"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "targetFiles",
          "reason",
          "validation",
          "expectedFindingsResolved",
          "status",
          "ownerDocs",
          "cleanupKind",
          "operations"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "code_fix",
              "rule_fix"
            ]
          },
          "targetFiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expectedFindingsResolved": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "planned"
            ]
          },
          "ownerDocs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cleanupKind": {
            "type": "string",
            "enum": [
              "",
              "delete_unused",
              "simplify_inline"
            ]
          },
          "operations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "targetPath",
                "content",
                "referenceTokens"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "write_file",
                    "delete_file"
                  ]
                },
                "targetPath": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                },
                "referenceTokens": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "actionItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "severity",
          "summary",
          "details",
          "relatedPaths"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "relatedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "blocked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reasonCode",
          "summary",
          "targetFiles"
        ],
        "properties": {
          "reasonCode": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "targetFiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
